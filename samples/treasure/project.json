    "scripts": {
      "adapt_direction": {
        "name": "adapt_direction",
        "asset_type": "script",
        "code": "# This script adapts the direction of the monster\n# when it comes at a possible crossing\n\nif instance.hspeed == 0:\n    if random.random() * 3<1 and not game.check_collision_at_position(instance, instance.x-4, instance.y, \"solid\"):\n        instance.hspeed = -4\n        instance.vspeed = 0\n    if random.random() * 3<1 and not game.check_collision_at_position(instance, instance.x+4, instance.y, \"solid\"):\n        instance.hspeed = 4\n        instance.vspeed = 0\nelse:\n    if random.random() * 3<1 and not game.check_collision_at_position(instance, instance.x, instance.y-4, \"solid\"):\n        instance.hspeed = 0\n        instance.vspeed = -4\n    if random.random() * 3<1 and not game.check_collision_at_position(instance, instance.x, instance.y+4, \"solid\"):\n        instance.hspeed = 0\n        instance.vspeed = 4",
        "language": "python",
        "imported": true,
        "created": "2026-07-17T10:51:41.717834",
        "modified": "2026-07-17T10:51:41.717834"
      }
